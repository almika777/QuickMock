@using QuickMock.Controllers

<!DOCTYPE html>
<html data-bs-theme="dark" lang="en">
<head>
    <!-- CDN для разработки -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-4Q6Gf2aSP4eDXB8Miphtr37CMZZQ5oXLH2yaXMJ2w8e2ZtHTl7GptT4jmndRuHDT" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <title></title>
</head>
<body>
@{
    var hostname = Context.Request.Host.Value;
}

<div class="container my-3">
    <ul class="nav nav-underline d-flex">
        <li class="nav-item">
            <a href="@Url.Action("Index", "Request")" 
               class="nav-link @IsActive(nameof(RequestController.Index))">
                Index
            </a>
        </li>
        <li class="nav-item">
            <a href="@Url.Action("Requests", "Request")" 
               class="nav-link @IsActive(nameof(RequestController.Requests))">
                Requests
            </a>
        </li>
        <li class="nav-item">
            <a href="@Url.Action("RequestAdd", "Request")"
               class="nav-link @IsActive(nameof(RequestController.RequestAdd))">
                New request
            </a>
        </li>
        <li class="nav-item ms-auto">
            <p class="nav-link disabled">Your host is:
                <mark>@hostname</mark>
            </p>
        </li>
    </ul>

    @RenderBody()
    @await RenderSectionAsync("Scripts", required: false)
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-j1CDi7MgGQ12Z7Qab0qlWQ/Qqz24Gc6BM0thvEMVjHnfYGF0rmFCozFSxQBxwHKO"
        crossorigin="anonymous"></script>
</body>
</html>

@functions {

    private string IsActive(string action)
    {
        return ViewContext.RouteData.Values["Action"]?.ToString() == action ? "active" : "";
    }

}