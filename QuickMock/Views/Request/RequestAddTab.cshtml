@model QuickMock.Models.Request.RequestAddModel

@using (Html.BeginForm("Add", "Request", FormMethod.Post, new { @class = "border p-4 rounded shadow-sm bg-light" }))
{
    @Html.AntiForgeryToken()

    <h4 class="mb-4 text-center">Добавить запрос</h4>

    <div class="mb-3">
        @Html.LabelFor(x => x.Path, "URL", new { @class = "form-label" })
        @Html.TextBoxFor(x => x.Path, new { @class = "form-control", placeholder = "https://localhost:5000/example/first" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(x => x.Value, "Значение (JSON или текст)", new { @class = "form-label" })
        @Html.TextAreaFor(x => x.Value, new { @class = "form-control", rows = "4", placeholder = "Введите данные..." })
    </div>

    <div class="mb-3 form-check">
        @Html.CheckBoxFor(x => x.IgnoreQueryString, new { @class = "form-check-input", id = "ignoreQuery" })
        @Html.LabelFor(x => x.IgnoreQueryString, "Игнорировать параметры после ?", new { @class = "form-check-label", @for = "ignoreQuery" })
    </div>

    <div class="d-grid">
        <button type="submit" class="btn btn-primary">Отправить</button>
    </div>
}